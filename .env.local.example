# =============================================================================
# Local Development Environment
# =============================================================================
# Copy to .env.local and customize for your local machine
# =============================================================================

# Project
PROJECT_NAME=dx-project
PROJECT_TYPE=hybrid
NODE_ENV=development

# Kubernetes (Local/Minikube)
NAMESPACE=local-dev
RELEASE_NAME=my-app-local
KUBECONFIG=$HOME/.kube/config

# Docker Registry (Local)
DOCKER_REGISTRY=localhost:5000
IMAGE_NAME=my-app
IMAGE_TAG=dev

# DX Portal (Local or Dev Instance)
DX_PROTOCOL=http
DX_HOSTNAME=localhost
DX_PORT=10042
DX_USERNAME=<local-dx-username>
DX_PASSWORD=<local-dx-password>

# Script Portlet
WCM_CONTENT_NAME="My App (Local)"
WCM_SITE_AREA="Applications"
PORTLET_MAIN_HTML=index.html
PORTLET_BUILD_DIR=./packages/portlet-v1/dist

# Backend Service (Local)
SERVICE_PORT=3000
HOST=localhost
API_BASE_URL=http://localhost:3000

# HAProxy (Disabled for local)
HAPROXY_ENABLED=false

# Helm
HELM_CHART_PATH=./helm/dam-plugin
VALUES_FILE=

# Port Forwarding (For K8s services)
LOCAL_PORT=3000
REMOTE_PORT=3000
DEPLOYMENT_NAME=dam-plugin

# Plugin Configuration (Local)
PLUGIN_CONFIG_FILE=./plugin-config.json
PLUGIN_NAME=my-plugin-local
PLUGIN_AUTH_KEY=local-plugin-auth-key
PLUGIN_URL=

# DAM Configuration (Local)
DAM_URL=http://localhost:3001
DAM_CALLBACK_URL=http://localhost:3000/callback
DAM_CONFIGMAP_SUFFIX=digital-asset-management
DAM_LOG_LEVEL=debug

# API Keys (Local/Development - NOT FOR PRODUCTION)
API_KEY=local-dev-key-not-for-production
JWT_SECRET=local-dev-secret-min-32-chars-please

# Logging (Verbose for debugging)
LOG_LEVEL=debug
DEBUG=app:*,plugin:*,loopback:*

# File Upload (Relaxed limits)
MAX_FILE_SIZE=524288000
# 500MB for local testing

ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# External Services (Mock/Sandbox)
EXTERNAL_API_KEY=sandbox-api-key
EXTERNAL_API_URL=https://sandbox-api.example.com/v1
EXTERNAL_API_TIMEOUT=30000

# CORS (Allow all for local dev)
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Rate Limiting (Disabled for local)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Feature Flags (All enabled for testing)
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_DEBUG_MODE=true
