{
  "name": "@dam-plugin/server-v1",
  "version": "1.0.0",
  "description": "DAM Plugin Server v1",
  "license": "SEE LICENSE IN LICENSE",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "build": "npm run clean && tsc && npm run openapi-spec",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint --ext .ts src",
    "lint:fix": "eslint --ext .ts --fix src",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:coverage": "jest --coverage",
    "openapi-spec": "ts-node openapi/generate.ts"
  },
  "dependencies": {
    "@dam-plugin/shared": "file:../shared",
    "@loopback/boot": "^7.0.0",
    "@loopback/core": "^6.0.0",
    "@loopback/openapi-v3": "^10.0.0",
    "@loopback/repository": "^7.0.0",
    "@loopback/rest": "^14.0.0",
    "@loopback/rest-explorer": "^7.0.0",
    "@loopback/service-proxy": "^7.0.0",
    "axios": "^1.6.0",
    "busboy": "^1.6.0",
    "canvas": "^2.11.2",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.0",
    "loopback-connector-postgresql": "^8.0.5",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "sharp": "^0.33.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/jest": "^29.5.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
