# =============================================================================
# Production Environment
# =============================================================================
# Copy to .env.prod and fill in actual values
# 
# SECURITY REQUIREMENTS FOR PRODUCTION:
# ========================================
# ✅ ALL credentials MUST be stored in Kubernetes secrets or secrets manager
# ✅ This file should only contain non-sensitive configuration
# ✅ Rotate all keys and passwords regularly
# ✅ Enable audit logging
# ✅ Review security settings before deployment
# ✅ Never use default passwords or keys
# ✅ Enable SSL/TLS for all connections
# =============================================================================

# Project
PROJECT_NAME=dx-project
PROJECT_TYPE=hybrid
NODE_ENV=production

# Kubernetes (Production Cluster)
NAMESPACE=<project-name>-prod
RELEASE_NAME=<project-name>-prod
KUBECONFIG=$HOME/.kube/config-prod

# Docker Registry (Production)
DOCKER_REGISTRY=<registry-host>/<production-repository>
IMAGE_NAME=<your-image-name>
IMAGE_TAG=v1.0.0
# IMPORTANT: Use semantic versioning in production (v1.0.0, v1.0.1, etc.)

# DX Portal (Production Instance)
DX_PROTOCOL=https
DX_HOSTNAME=<dx-prod-hostname>
# Example: dx.example.com
DX_PORT=443

# SECURITY: DO NOT store credentials in this file
# Use: kubectl create secret generic dx-credentials --from-literal=username=xxx --from-literal=password=xxx
DX_USERNAME=<read-from-k8s-secret>
DX_PASSWORD=<read-from-k8s-secret>

# Script Portlet
WCM_CONTENT_NAME="<Your App>"
WCM_SITE_AREA="Applications"
PORTLET_MAIN_HTML=index.html
PORTLET_BUILD_DIR=./packages/portlet-v1/dist

# Backend Service
SERVICE_PORT=3000
HOST=0.0.0.0
API_BASE_URL=https://<dx-prod-hostname>/api/<service-path>

# HAProxy
HAPROXY_ENABLED=true
HAPROXY_NAMESPACE=<project-name>-prod
INGRESS_CLASS=haproxy
INGRESS_PATHS=/api/<service-path>

# Helm
HELM_CHART_PATH=./helm/dam-plugin
VALUES_FILE=./helm/dam-plugin/values-prod.yaml

# Port Forwarding (Should not be needed in production)
LOCAL_PORT=3000
REMOTE_PORT=3000
DEPLOYMENT_NAME=<deployment-name>

# Plugin Configuration (Production)
PLUGIN_CONFIG_FILE=./plugin-config.json
PLUGIN_NAME=<plugin-name>
PLUGIN_AUTH_KEY=<read-from-k8s-secret>
# SECURITY: MUST use Kubernetes secrets
PLUGIN_URL=

# DAM Configuration (Production)
DAM_URL=http://<namespace>-digital-asset-management:3000
DAM_CALLBACK_URL=http://<plugin-service>:3000/callback
DAM_CONFIGMAP_SUFFIX=digital-asset-management
DAM_LOG_LEVEL=error

# API Keys (Production)
# SECURITY: MUST use Kubernetes secrets
API_KEY=<read-from-k8s-secret>
JWT_SECRET=<read-from-k8s-secret>

# Logging (Production - errors and warnings only)
LOG_LEVEL=error
DEBUG=
# IMPORTANT: Never enable DEBUG in production

# File Upload (Production limits)
MAX_FILE_SIZE=52428800
# 50MB (stricter than dev/uat)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# External Services (Production)
# SECURITY: MUST use Kubernetes secrets
EXTERNAL_API_KEY=<read-from-k8s-secret>
EXTERNAL_API_URL=<prod-external-api-url>
EXTERNAL_API_TIMEOUT=10000
# Shorter timeout in production for fast failure

# CORS (Production - strict, never use wildcard)
CORS_ORIGIN=https://<dx-prod-hostname>
# CRITICAL: NEVER use * in production
CORS_CREDENTIALS=true

# Rate Limiting (Strict)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=50
# Lower limit to prevent abuse

# Feature Flags
ENABLE_METRICS=true
ENABLE_TRACING=false
# Enable tracing only when debugging production issues
ENABLE_DEBUG_MODE=false
# MUST be false in production
