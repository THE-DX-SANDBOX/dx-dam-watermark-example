# =============================================================================
# UAT/Staging Environment
# =============================================================================
# Copy to .env.uat and fill in actual values
# REQUIRED: Use Kubernetes secrets for all credentials in UAT
# =============================================================================

# Project
PROJECT_NAME=dx-project
PROJECT_TYPE=hybrid
NODE_ENV=staging

# Kubernetes (UAT Cluster)
NAMESPACE=<project-name>-uat
RELEASE_NAME=<project-name>-uat
KUBECONFIG=$HOME/.kube/config-uat

# Docker Registry (UAT)
DOCKER_REGISTRY=<registry-host>/<uat-repository>
IMAGE_NAME=<your-image-name>
IMAGE_TAG=uat

# DX Portal (UAT Instance)
DX_PROTOCOL=https
DX_HOSTNAME=<dx-uat-hostname>
# Example: dx-uat.example.com
DX_PORT=443
DX_USERNAME=<uat-service-account>
DX_PASSWORD=<uat-service-account-password>
# REQUIRED: Use Kubernetes secrets in UAT

# Script Portlet
WCM_CONTENT_NAME="<Your App> (UAT)"
WCM_SITE_AREA="Applications"
PORTLET_MAIN_HTML=index.html
PORTLET_BUILD_DIR=./packages/portlet-v1/dist

# Backend Service
SERVICE_PORT=3000
HOST=0.0.0.0
API_BASE_URL=https://<dx-uat-hostname>/api/<service-path>

# HAProxy
HAPROXY_ENABLED=true
HAPROXY_NAMESPACE=<project-name>-uat
INGRESS_CLASS=haproxy
INGRESS_PATHS=/api/<service-path>

# Helm
HELM_CHART_PATH=./helm/dam-plugin
VALUES_FILE=./helm/dam-plugin/values-uat.yaml

# Port Forwarding
LOCAL_PORT=3000
REMOTE_PORT=3000
DEPLOYMENT_NAME=<deployment-name>

# Plugin Configuration (UAT)
PLUGIN_CONFIG_FILE=./plugin-config.json
PLUGIN_NAME=<plugin-name>-uat
PLUGIN_AUTH_KEY=<uat-plugin-auth-key>
# REQUIRED: Use Kubernetes secrets
PLUGIN_URL=

# DAM Configuration (UAT)
DAM_URL=http://<namespace>-digital-asset-management:3000
DAM_CALLBACK_URL=http://<plugin-service>:3000/callback
DAM_CONFIGMAP_SUFFIX=digital-asset-management
DAM_LOG_LEVEL=info

# API Keys (UAT)
API_KEY=<uat-api-key>
JWT_SECRET=<uat-jwt-secret-min-32-chars>
# REQUIRED: Use Kubernetes secrets

# Logging (Info level)
LOG_LEVEL=info
DEBUG=
DAM_LOG_LEVEL=info

# File Upload
MAX_FILE_SIZE=104857600
# 100MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# External Services (UAT)
EXTERNAL_API_KEY=<uat-external-api-key>
EXTERNAL_API_URL=<uat-external-api-url>
EXTERNAL_API_TIMEOUT=30000

# CORS (UAT - specific origin)
CORS_ORIGIN=https://<dx-uat-hostname>
CORS_CREDENTIALS=true

# Rate Limiting (Production-like)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_DEBUG_MODE=false
