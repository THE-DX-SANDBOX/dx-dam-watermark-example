# ===============================================================
# DAM Plugin Environment Variables - Master Template
# ===============================================================
# 
# This is a comprehensive template showing all available configuration options.
# DO NOT use this directly - copy to environment-specific files:
#
# For local development:    cp .env.local.example .env.local
# For dev cluster:          cp .env.dev.example .env.dev  
# For UAT/staging:          cp .env.uat.example .env.uat
# For production:           cp .env.prod.example .env.prod
#
# See environment-specific examples for security requirements and best practices.
# ===============================================================

# ---------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------
PORT=3000                           # Service listens on this port
HOST=0.0.0.0                        # Bind to all interfaces (container default)
NODE_ENV=development                # development | test | uat | production
APP_VERSION=1.0.0                   # Application version (use semantic versioning)

# ---------------------------------------------------------------
# Logging Configuration
# ---------------------------------------------------------------
LOG_LEVEL=debug                     # error | warn | info | debug | trace
DEBUG=plugin:*                      # Debug namespaces (e.g., plugin:*, loopback:*)
LOG_FORMAT=json                     # json | text
LOG_OUTPUT=stdout                   # stdout | file | both
LOG_FILE_PATH=./logs/app.log        # If LOG_OUTPUT includes 'file'

# ---------------------------------------------------------------
# Security & Authentication
# ---------------------------------------------------------------
API_KEY=<api-key>                   # REQUIRED: Main API authentication key
JWT_SECRET=<jwt-secret-min-32-chars> # REQUIRED: JWT token signing secret (min 32 chars)
JWT_EXPIRES_IN=1h                   # JWT token expiration (e.g., 1h, 24h, 7d)
CORS_ORIGIN=*                       # CORS allowed origins (* for dev, specific URLs for prod)
RATE_LIMIT_MAX=100                  # Max requests per window
RATE_LIMIT_WINDOW=15m               # Rate limit time window

# ---------------------------------------------------------------
# File Upload Configuration
# ---------------------------------------------------------------
MAX_FILE_SIZE=104857600             # 100MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_TEMP_DIR=/tmp/uploads        # Temporary upload directory
UPLOAD_RETAIN_DAYS=7                # Days to retain temporary files

# ---------------------------------------------------------------
# HCL DX DAM Integration
# ---------------------------------------------------------------
DAM_HOST=https://<dx-hostname>      # REQUIRED: HCL DX server URL
DAM_API_KEY=<dam-api-key>           # REQUIRED: DAM API key for authentication
DAM_PLUGIN_ID=<plugin-id>           # Your plugin's unique identifier
DAM_TIMEOUT=30000                   # DAM API timeout in milliseconds

# ---------------------------------------------------------------
# External Services (customize for your plugin)
# ---------------------------------------------------------------
EXTERNAL_API_KEY=<external-api-key>
EXTERNAL_API_URL=https://api.example.com/v1
EXTERNAL_API_TIMEOUT=30000          # milliseconds

# ---------------------------------------------------------------
# Database Configuration (if needed)
# ---------------------------------------------------------------
DB_TYPE=postgres                    # postgres | mysql | mongodb
DB_HOST=<database-host>
DB_PORT=5432
DB_NAME=<database-name>
DB_USER=<database-user>
DB_PASSWORD=<database-password>
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false                        # Enable SSL for database connections

# ---------------------------------------------------------------
# Redis/Cache Configuration (if needed)
# ---------------------------------------------------------------
REDIS_HOST=<redis-host>
REDIS_PORT=6379
REDIS_PASSWORD=                     # Leave empty if no password
REDIS_DB=0
REDIS_TTL=3600                      # Default cache TTL in seconds

# ---------------------------------------------------------------
# Kubernetes Configuration
# ---------------------------------------------------------------
K8S_NAMESPACE=<namespace>           # Kubernetes namespace
K8S_SERVICE_NAME=dam-plugin-service # Kubernetes service name
K8S_CLUSTER=<cluster-name>          # Cluster identifier
K8S_REGION=<region>                 # Cloud region

# Build & Registry
DOCKER_REGISTRY=<registry-host>/<repository>
HELM_REGISTRY=<registry-host>/<helm-repository>
IMAGE_NAME=dam-plugin
IMAGE_TAG=latest

# DX Portal
DX_PROTOCOL=https
DX_HOSTNAME=<dx-hostname>
DX_PORT=443
DX_USERNAME=<dx-username>
DX_PASSWORD=<dx-password>

# Plugin & DAM Runtime
PLUGIN_CONFIG_FILE=./plugin-config.json
PLUGIN_NAME=<plugin-name>
PLUGIN_AUTH_KEY=<plugin-auth-key>
PLUGIN_URL=
DAM_URL=http://<dam-service-name>:3000
DAM_CALLBACK_URL=http://<plugin-service-name>:3000/callback

# ---------------------------------------------------------------
# HAProxy Integration
# ---------------------------------------------------------------
HAPROXY_ENABLED=true                # Enable Custom HAProxy routing
HAPROXY_PATH_PREFIX=/api/dam-plugin # URL path prefix for routing
HAPROXY_HEALTH_CHECK=/health        # Health check endpoint
HAPROXY_BACKEND_NAME=dam-plugin-backend

# ---------------------------------------------------------------
# Monitoring & Observability
# ---------------------------------------------------------------
METRICS_ENABLED=true                # Enable Prometheus metrics
METRICS_PORT=9090                   # Metrics endpoint port
HEALTH_CHECK_PATH=/health           # Health check endpoint
READINESS_CHECK_PATH=/ready         # Readiness check endpoint

# ---------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------
FEATURE_IMAGE_PROCESSING=true       # Enable image processing features
FEATURE_VIDEO_PROCESSING=false      # Enable video processing features
FEATURE_AI_TAGGING=true             # Enable AI-based tagging

# ---------------------------------------------------------------
# Deployment Configuration
# ---------------------------------------------------------------
HELM_RELEASE_NAME=dam-plugin        # Helm release name
HELM_CHART_VERSION=1.0.0            # Helm chart version
REPLICAS=2                          # Number of pod replicas
RESOURCE_LIMITS_CPU=500m            # CPU limit
RESOURCE_LIMITS_MEMORY=512Mi        # Memory limit
