{
  "name": "dam-plugin",
  "version": "1.0.0",
  "description": "HCL DAM Plugin Template",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "author": "",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "bootstrap": "npx lerna bootstrap",
    "clean": "npx lerna clean -y",
    "build": "npx lerna run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "start": "cd packages/server-v1 && npm start",
    "dev": "cd packages/server-v1 && npm run dev",
    "test": "npx lerna run test",
    "test:coverage": "npx lerna run test:coverage",
    "lint": "npx lerna run lint",
    "lint:fix": "npx lerna run lint:fix",
    "docker:build": "./scripts/build.sh",
    "docker:build:push": "./scripts/build.sh --push",
    "docker:build:helm": "./scripts/build.sh --push --helm",
    "docker:run": "docker-compose -f packages/docker-compose.yml up",
    "docker:stop": "docker-compose -f packages/docker-compose.yml down",
    "deploy": "./scripts/deploy.sh",
    "deploy:dev": "./scripts/deploy.sh dev",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:prod": "./scripts/deploy.sh prod",
    "deploy:quick": "./scripts/quick-deploy.sh",
    "undeploy": "./scripts/undeploy.sh",
    "test:plugin": "./scripts/test-plugin.sh",
    "test:watermark": "./scripts/test-watermark.sh",
    "test:local": "./scripts/test-local.sh",
    "pipeline": "./scripts/build-and-deploy.sh",
    "pipeline:dev": "./scripts/build-and-deploy.sh dev",
    "pipeline:staging": "./scripts/build-and-deploy.sh staging",
    "pipeline:prod": "./scripts/build-and-deploy.sh prod",
    "pipeline:helm": "UPDATE_HELM=true ./scripts/build-and-deploy.sh",
    "setup": "./scripts/make-executable.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "lerna": "^8.0.0",
    "typescript": "^5.3.0",
    "vitepress": "^1.6.3",
    "vue": "^3.5.13"
  }
}
