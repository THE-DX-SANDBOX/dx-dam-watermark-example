# =============================================================================
# Development Environment (Shared Dev Cluster)
# =============================================================================
# Copy to .env.dev and fill in actual values
# =============================================================================

# Project
PROJECT_NAME=<project-name>
PROJECT_TYPE=hybrid
NODE_ENV=development

# Kubernetes (Dev Cluster)
NAMESPACE=<project-name>-dev
RELEASE_NAME=<project-name>-dev
KUBECONFIG=$HOME/.kube/config-dev

# Docker Registry (Development)
DOCKER_REGISTRY=<registry-host>/<development-repository>
IMAGE_NAME=<your-image-name>
IMAGE_TAG=dev

# DX Portal (Dev Instance)
DX_PROTOCOL=https
DX_HOSTNAME=<dx-dev-hostname>
# Example: <dx-dev-hostname>
DX_PORT=443
DX_USERNAME=<dev-service-account>
DX_PASSWORD=<dx-password>
# TODO: Move to Kubernetes secrets

# Script Portlet
WCM_CONTENT_NAME="<Your App> (DEV)"
WCM_SITE_AREA="Applications"
PORTLET_MAIN_HTML=index.html
PORTLET_BUILD_DIR=./packages/portlet-v1/dist

# Backend Service
SERVICE_PORT=3000
HOST=0.0.0.0
API_BASE_URL=https://<dx-dev-hostname>/api/<service-path>

# HAProxy
HAPROXY_ENABLED=true
HAPROXY_NAMESPACE=<project-name>-dev
INGRESS_CLASS=haproxy
INGRESS_PATHS=/api/<service-path>

# Helm
HELM_CHART_PATH=./helm/dam-plugin
VALUES_FILE=./helm/dam-plugin/values-dev.yaml

# Port Forwarding
LOCAL_PORT=3000
REMOTE_PORT=3000
DEPLOYMENT_NAME=<deployment-name>

# Plugin Configuration (Dev)
PLUGIN_CONFIG_FILE=./plugin-config.json
PLUGIN_NAME=<plugin-name>-dev
PLUGIN_AUTH_KEY=<plugin-auth-key>
PLUGIN_URL=

# DAM Configuration (Dev)
DAM_URL=http://<dam-service-name>:3000
DAM_CALLBACK_URL=http://<plugin-service>:3000/callback
DAM_CONFIGMAP_SUFFIX=digital-asset-management
DAM_LOG_LEVEL=debug

# API Keys (Dev)
API_KEY=<api-key>
JWT_SECRET=<jwt-secret-min-32-chars>
# TODO: Move to Kubernetes secrets

# Logging (Debug enabled)
LOG_LEVEL=debug
DEBUG=app:*,plugin:*
DAM_LOG_LEVEL=debug

# File Upload
MAX_FILE_SIZE=104857600
# 100MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# External Services (Dev/Sandbox)
EXTERNAL_API_KEY=<external-api-key>
EXTERNAL_API_URL=<external-api-url>
EXTERNAL_API_TIMEOUT=30000

# CORS (Dev - specific origins)
CORS_ORIGIN=https://<dx-dev-hostname>
CORS_CREDENTIALS=true

# Rate Limiting (Relaxed)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200

# Feature Flags
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_DEBUG_MODE=true
